client/node_modules
# The image builds the client itself in the client-builder stage (#111), so exclude any prebuilt
# bundle from the context — this keeps the in-Dockerfile build cache-stable across runs.
client/dist

*.egg-info
*.egg/
*.pyc
*.swp
__pycache__

# Version control and editor/IDE metadata
.git
.github
.vscode
.idea

# Test artifacts and suites (not needed for the image build)
.pytest_cache
tests
tests_integration

# Home Assistant add-on packaging (#89) — packaged separately, not part of the server image
ha-addon

# Environment files (keep the example for reference). dockerignore patterns are anchored to
# the context root, so the client's env files need their own entries — without them a local
# developer client/.env (any VITE_* vars) silently bakes into locally built images. The
# image's own .env.production is generated inside the client-builder stage after the COPY.
.env
.env.*
!.env.example
client/.env
client/.env.*
