exports[`plan snapshots > compose-switch-from-native 1`] = `
{
  "artifacts": [
    {
      "content": "services:
  spoolman:
    image: ghcr.io/sherrmann/spoolman-ng:latest # Also on Docker Hub: cookiemonster95/spoolman-ng:latest
    restart: unless-stopped
    volumes:
      # Keeps your database outside the container lifecycle. Do NOT modify the target path.
      - ./data:/home/app/.local/share/spoolman
    ports:
      - "7912:8000"
    environment:
      - TZ=Europe/Stockholm # timezone, used for timestamps in the UI/API
",
      "filename": "docker-compose.yml",
      "id": "compose",
      "language": "yaml",
      "title": "docker-compose.yml",
    },
  ],
  "steps": [
    {
      "commands": [
        "sudo systemctl stop Spoolman",
      ],
      "id": "switch-stop-native",
      "title": "Stop the native service",
    },
    {
      "artifactIds": [
        "compose",
      ],
      "body": "Create an empty directory (e.g. ~/spoolman) and save this file in it as docker-compose.yml.",
      "id": "compose-file",
      "title": "Create a folder and save docker-compose.yml",
    },
    {
      "body": "Your data lives in one place regardless of install method — switching is just moving the data directory.",
      "commands": [
        "mkdir -p ./data",
        "cp -a ~/.local/share/spoolman/. ./data/",
      ],
      "id": "switch-copy-data",
      "notes": [
        {
          "id": "stop-both-sides",
          "level": "warning",
          "text": "Stop Spoolman on both sides before copying, and copy the whole directory (database plus backups/). If you use a custom SPOOLMAN_DIR_DATA, copy that directory instead.",
        },
      ],
      "title": "Copy your data into the bind mount",
    },
    {
      "commands": [
        "docker compose up -d",
      ],
      "id": "start",
      "notes": [
        {
          "id": "spoolman-url-unchanged",
          "level": "info",
          "text": "Your printers' [spoolman] sections keep working unchanged — the server stays on port 7912.",
        },
      ],
      "title": "Start it",
    },
    {
      "body": "Disable the systemd unit and delete ~/Spoolman — keep the old data directory until you've verified the Docker install (see Uninstalling in the installation guide: https://github.com/sherrmann/Spoolman-NG/blob/master/docs/installation.md).",
      "id": "switch-cleanup",
      "title": "Once happy, remove the native install",
    },
  ],
  "warnings": [],
}
`;

exports[`plan snapshots > helm-mysql-token 1`] = `
{
  "artifacts": [
    {
      "content": "# Spoolman-NG Helm values. Install with:
#   helm install spoolman oci://ghcr.io/sherrmann/charts/spoolman-ng -f values.yaml

env:
  SPOOLMAN_DB_TYPE: mysql
  SPOOLMAN_DB_HOST: my-database-host # point at your database server; the chart bundles none
  SPOOLMAN_DB_PORT: "3306"
  SPOOLMAN_DB_NAME: spoolman
  SPOOLMAN_DB_USERNAME: spoolman
  SPOOLMAN_API_TOKEN: change-me # generate one: openssl rand -hex 32

# Mounts the secret's key as a file (SPOOLMAN_DB_PASSWORD_FILE) — no password in values.
dbPasswordSecret:
  name: spoolman-db
  key: password

ingress:
  enabled: true
  hosts:
    - host: spoolman.example.com
      paths: [{ path: /, pathType: Prefix }]
",
      "filename": "values.yaml",
      "id": "values",
      "language": "yaml",
      "title": "values.yaml (Helm)",
    },
  ],
  "steps": [
    {
      "body": "The chart bundles no database — point SPOOLMAN_DB_HOST at one you run. The password is mounted from a Secret (never in values):",
      "commands": [
        "kubectl create secret generic spoolman-db --from-literal=password='change-me'",
      ],
      "id": "db-secret",
      "title": "Create the database password secret",
    },
    {
      "artifactIds": [
        "values",
      ],
      "id": "values",
      "notes": undefined,
      "title": "Save values.yaml",
    },
    {
      "body": "Defaults: one replica (the bundled SQLite database is single-writer), a 1 Gi PVC, health probes, non-root security context.",
      "commands": [
        "helm install spoolman oci://ghcr.io/sherrmann/charts/spoolman-ng -f values.yaml",
      ],
      "id": "helm-install",
      "title": "Install the chart",
    },
    {
      "body": "Via your Ingress: http(s)://spoolman.example.com.",
      "id": "access",
      "title": "Open the UI",
    },
  ],
  "warnings": [],
}
`;

