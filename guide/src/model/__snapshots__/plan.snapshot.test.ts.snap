{
  "artifacts": [
    {
      "content": "# Spoolman-NG Helm values. Install with:
#   helm install spoolman oci://ghcr.io/sherrmann/charts/spoolman-ng -f values.yaml

env:
  SPOOLMAN_BASE_PATH: /spoolman
  SPOOLMAN_DB_TYPE: postgres
