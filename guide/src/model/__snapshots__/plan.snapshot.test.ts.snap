  SPOOLMAN_DB_PORT: "5432"
  SPOOLMAN_DB_NAME: spoolman
  SPOOLMAN_DB_USERNAME: spoolman

# Mounts the secret's key as a file (SPOOLMAN_DB_PASSWORD_FILE) — no password in values.
dbPasswordSecret:
  name: spoolman-db
  key: password

# Sub-path serving: the base path and the probe path must move together.
probes:
  path: /spoolman/api/v1/health
",
      "filename": "values.yaml",
      "id": "values",
      "language": "yaml",
      "title": "values.yaml (Helm)",
    },
  ],
  "steps": [
    {
      "body": "The chart bundles no database — point SPOOLMAN_DB_HOST at one you run. The password is mounted from a Secret (never in values):",
      "commands": [
        "kubectl create secret generic spoolman-db --from-literal=password='change-me'",
      ],
      "id": "db-secret",
      "title": "Create the database password secret",
    },
    {
      "artifactIds": [
        "values",
      ],
      "id": "values",
      "notes": undefined,
      "title": "Save values.yaml",
    },
    {
      "body": "Defaults: one replica (the bundled SQLite database is single-writer), a 1 Gi PVC, health probes, non-root security context.",
      "commands": [
        "helm install spoolman oci://ghcr.io/sherrmann/charts/spoolman-ng -f values.yaml",
      ],
      "id": "helm-install",
      "title": "Install the chart",
    },
    {
      "body": "No Ingress configured — reach it with kubectl port-forward against the service the chart created (kubectl get svc), or add ingress: to values.yaml later.",
      "id": "access",
      "title": "Open the UI",
    },
  ],
  "warnings": [],
}
`;

