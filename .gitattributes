# Handle line endings automatically for files detected as text 
# and leave all files detected as binary untouched.
* text=auto

# Shell scripts must stay LF even on Windows checkouts ("-crlf" is legacy
# syntax that text=auto overrides; a CRLF entrypoint.sh breaks the Docker
# image with "exec: no such file or directory").
*.sh text eol=lf
.env.example text eol=lf