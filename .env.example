# DB Type: sqlite, mysql, postgres, cockroachdb
# Default if not set: sqlite
#SPOOLMAN_DB_TYPE=sqlite

# DB Setup, if not using sqlite
# Database hostname
#SPOOLMAN_DB_HOST=
# Database port
#SPOOLMAN_DB_PORT=
# Database name
#SPOOLMAN_DB_NAME=
# Database login username
#SPOOLMAN_DB_USERNAME=
# Path of file which contains the database password. Can be used instead of SPOOLMAN_DB_PASSWORD if desired.
#SPOOLMAN_DB_PASSWORD_FILE=
# Database login password
#SPOOLMAN_DB_PASSWORD=
# Query parameters for the database connection, e.g. set to `unix_socket=/path/to/mysql.sock` to connect using a MySQL socket.
#SPOOLMAN_DB_QUERY=
# PostgreSQL/CockroachDB only: schema (search_path) to place Spoolman's tables in on a shared
# database (e.g. Supabase). The schema is created if it does not exist. Ignored for MySQL/SQLite.
#SPOOLMAN_DB_SCHEMA=

# Optional API authentication. When set, all /api/v1 requests require an
# `Authorization: Bearer <token>` header (websockets use a `?token=` query parameter instead),
# except GET /health and the OpenAPI docs. Leave unset for the default no-auth behaviour.
# OctoPrint's Spoolman plugin can send the token (API-key header 'Authorization', value 'Bearer <token>');
# Moonraker CANNOT (no auth option) — do not set a token on an instance Klipper printers report to.
#SPOOLMAN_API_TOKEN=

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Logs will only be reported if the level is higher than the level set here
# Default if not set: INFO
#SPOOLMAN_LOGGING_LEVEL=INFO

# Automatic nightly backup for SQLite databases
# Default if not set: TRUE
#SPOOLMAN_AUTOMATIC_BACKUP=TRUE

# Release update check. Once a day the server asks GitHub whether a newer
# Spoolman-NG release exists and surfaces an "update available" hint in the UI
# (GET /api/v1/info exposes latest_version / update_available).
# Privacy: the ONLY outbound call is a single request to api.github.com; no
# telemetry or information about your install is sent. Conditional requests
# (ETag) keep it gentle on GitHub's rate limits.
# Set to FALSE to disable the check entirely (zero outbound calls).
# Accepts TRUE/1 or FALSE/0. Default if not set: TRUE
#SPOOLMAN_UPDATE_CHECK=TRUE

# Allow the UI to trigger a native self-update (runs the bundled scripts/update.sh).
# This is remote code execution by design, so it is NEVER exposed by default on an open
# instance: it is admin-only whenever authentication is configured (SPOOLMAN_API_TOKEN or
# user accounts), and otherwise stays disabled unless you set this to TRUE. Only affects
# native installs (release zip); Docker and Home Assistant add-ons update via their own
# tooling regardless of this setting.
# Accepts TRUE/1 or FALSE/0. Default if not set: FALSE
#SPOOLMAN_ALLOW_UI_UPDATE=FALSE

# Data directory, where the SQLite database is stored
# Default if not set: /home/<user>/.local/share/spoolman
#SPOOLMAN_DIR_DATA=/home/pi/spoolman_data

# Backup directory, where the SQLite database backups are stored
# Default if not set: /home/<user>/.local/share/spoolman/backups
#SPOOLMAN_DIR_BACKUPS=/home/pi/spoolman_data/backups

# Log directory
# Default if not set: /home/<user>/.local/share/spoolman
#SPOOLMAN_DIR_LOGS=/home/pi/spoolman_data

# Host and port to listen on
SPOOLMAN_HOST=0.0.0.0
SPOOLMAN_PORT=7912

# Change base path
# Set this if you want to host Spoolman at a sub-path
# If you want the root to be e.g. myhost.com/spoolman
# Then set this to /spoolman
#SPOOLMAN_BASE_PATH=

# Enable Collect Prometheus metrics at database
# Default: FALSE
#SPOOLMAN_METRICS_ENABLED=TRUE

# Collect items (filaments, materials, etc.) from an external database
# Set this to a URL of an external database. Set to an empty string to disable
# Default: https://sherrmann.github.io/SpoolmanDB/
#EXTERNAL_DB_URL=https://myhost.com/spoolmandb/
# Sync interval in seconds, set to 0 to disable automatic sync. It will only sync on start-up then.
# Default: 3600
#EXTERNAL_DB_SYNC_INTERVAL=3600
# Base URL for 3D Filament Profiles imports on the filament form.
# Point at a mirror/proxy if you cannot reach the live site.
# Default: https://3dfilamentprofiles.com
#EXTERNAL_3DFP_URL=https://3dfilamentprofiles.com

# Enable debug mode
# If enabled, the client will accept requests from any host
# This can be useful when developing, but is also a security risk
# Default: FALSE
#SPOOLMAN_DEBUG_MODE=TRUE

# UID and GID of the user in the docker container
# These only make sense if you are running Spoolman in a docker container
# Default if not set: 1000
#PUID=1000
#PGID=1000

# Allows CORS ORIGIN. 
# Use the https://developer.mozilla.org/en-US/docs/Web/HTTP/Reference/Headers/Access-Control-Allow-Origin semantics
# separated by commas
# for example to allow request from source1.domain.com on port p1 and source2.domain.com on port p2
# SPOOLMAN_CORS_ORIGIN=source1.domain.com:p1, source2.domain.com:p2
# to allow from any
# SPOOLMAN_CORS_ORIGIN=*

# Extra Android signing-cert SHA-256 fingerprints served in
# /.well-known/assetlinks.json (companion-app passkeys). Only needed for
# self-built APKs — the released APK's fingerprint is always included.
# Comma-separated, colon-delimited hex as printed by
# `apksigner verify --print-certs` or the Mobile APK workflow summary.
#SPOOLMAN_ANDROID_CERT_FINGERPRINTS=AA:BB:...:99

# --- NFC (server-side USB reader) ---
# Full guide: docs/nfc.md. Only needed for a server-side USB NFC reader;
# in-browser Web NFC scanning needs no server config.
# Enable the server-side USB NFC reader (nfcpy). Accepts TRUE/1 or FALSE/0.
# Default: FALSE
#SPOOLMAN_NFC_ENABLED=TRUE
# Reader backend. Only "nfcpy" is implemented today.
# Default: nfcpy
#SPOOLMAN_NFC_READER_TYPE=nfcpy
# nfcpy connection string. Unset = auto-detect the first USB reader ("usb").
# Examples: usb, usb:04e6:5591 (VID:PID), usb:001:005 (bus:device), tty:USB0:pn532
#SPOOLMAN_NFC_DEVICE=usb

# --- TigerTag external product-database lookups (optional; NOT the reader) ---
# Enrich scanned TigerTag tags from tigertag.io's product API.
# Enable TigerTag lookups. Accepts TRUE/1 or FALSE/0.
# Default: FALSE
#SPOOLMAN_TIGERTAG_ENABLED=TRUE
# TigerTag API base URL.
# Default: https://api.tigertag.io/api:tigertag/
#SPOOLMAN_TIGERTAG_API_URL=https://api.tigertag.io/api:tigertag/
# TigerTag product-table sync interval, in seconds.
# Default: 3600
#SPOOLMAN_TIGERTAG_SYNC_INTERVAL=3600

# --- AI features (optional) ---
# Full guide: docs/ai.md. Spoolman never runs models itself — every AI feature
# talks to an OpenAI-compatible endpoint you configure. All of these can also be
# set in Settings → AI; a variable set here wins and locks the field in the UI.
# The OpenAI-compatible endpoint, e.g. an Ollama on your network.
#SPOOLMAN_AI_BASE_URL=http://localhost:11434/v1
# API key for the endpoint (Ollama and LM Studio need none). Overrides the
# write-only key stored via Settings → AI.
#SPOOLMAN_AI_API_KEY=sk-...
# Model used for chat, natural-language search and tools.
#SPOOLMAN_AI_MODEL=qwen3:8b
# Model used for image features (Scan-to-Spool); falls back to the chat model.
#SPOOLMAN_AI_VISION_MODEL=qwen2.5vl:7b
# Speech-to-text endpoint for voice input (OpenAI /audio/transcriptions API,
# e.g. Speaches or a whisper.cpp server — note Ollama has no speech-to-text).
# Unset = voice transcription rides on SPOOLMAN_AI_BASE_URL.
#SPOOLMAN_AI_STT_BASE_URL=http://localhost:8000/v1
# Transcription model, e.g. whisper-1 (OpenAI/Groq) or a faster-whisper name.
#SPOOLMAN_AI_STT_MODEL=whisper-1
# API key for a dedicated STT endpoint. The main key is never sent to it.
#SPOOLMAN_AI_STT_API_KEY=sk-...
